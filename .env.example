# Variables de entorno del Backend API LurisFlow
# Copiar como .env y completar con valores reales

# --- Base de Datos NEON ---
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/lurisflow?sslmode=require

# --- Clerk (Seguridad de Acceso) ---
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# --- Servidor ---
PORT=4000
NODE_ENV=development

# --- CORS: orígenes permitidos ---
# Web frontend (Vercel) y la app móvil via esquema custom
ALLOWED_ORIGINS=https://lurisflow.pe,https://app.lurisflow.pe,lurisflowapp://
